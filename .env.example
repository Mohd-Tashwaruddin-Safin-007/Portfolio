# Copy this file to api/.env for local development.
# On Render, set the same keys via the dashboard (Environment section).

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/portfolio?retryWrites=true&w=majority

# Database name
DB_NAME=portfolio

# Server port (Render overrides this automatically; only used locally)
PORT=5000

# Comma-separated list of allowed origins for CORS.
# Add your Vercel URL here, e.g. https://your-portfolio.vercel.app
CLIENT_ORIGIN=http://localhost:5173